APP_PORT=8080
MYSQL_BIND_ADDRESS=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=onepass_practice
MYSQL_USER=onepass
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_IMAGE=m.daocloud.io/docker.io/library/mysql:8.4

APP_JWT_SECRET=change-this-to-a-random-32-plus-character-secret
WECHAT_MINI_APP_ID=your-wechat-mini-program-appid
WECHAT_MINI_APP_SECRET=your-wechat-mini-program-secret
APP_CORS_ALLOWED_ORIGINS=https://api.example.com,https://admin.example.com
APP_MOCK_ENABLED=false
APP_ADMIN_IMPORT_TOKEN=change-this-admin-import-token

IMPORT_STORAGE_ROOT=/app/import-storage
IMPORT_DEFAULT_CATEGORY_PATH=考研/政治/基础阶段
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=50MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=60MB
SERVER_FORWARD_HEADERS_STRATEGY=framework
JAVA_OPTS=-XX:MaxRAMPercentage=75

DOCKER_BUILD_TARGET=packaged
MAVEN_IMAGE=m.daocloud.io/docker.io/library/maven:3.9.9-eclipse-temurin-17
RUNTIME_IMAGE=m.daocloud.io/docker.io/library/eclipse-temurin:17-jre
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public
