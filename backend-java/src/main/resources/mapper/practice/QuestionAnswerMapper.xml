<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.onepass.practice.practice.persistence.QuestionAnswerMapper">

    <resultMap id="QuestionAnswerMap" type="com.onepass.practice.practice.persistence.QuestionAnswerDO">
        <id property="id" column="id"/>
        <result property="questionId" column="question_id"/>
        <result property="answerKey" column="answer_key"/>
        <result property="sortOrder" column="sort_order"/>
    </resultMap>

    <select id="selectAll" resultMap="QuestionAnswerMap">
        SELECT id, question_id, answer_key, sort_order
        FROM question_answer
        ORDER BY question_id ASC, sort_order ASC, id ASC
    </select>
</mapper>
