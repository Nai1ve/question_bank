<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.onepass.practice.practice.persistence.QuestionOptionMapper">

    <resultMap id="QuestionOptionMap" type="com.onepass.practice.practice.persistence.QuestionOptionDO">
        <id property="id" column="id"/>
        <result property="questionId" column="question_id"/>
        <result property="optionKey" column="option_key"/>
        <result property="content" column="content"/>
        <result property="sortOrder" column="sort_order"/>
    </resultMap>

    <select id="selectAll" resultMap="QuestionOptionMap">
        SELECT id, question_id, option_key, content, sort_order
        FROM question_option
        ORDER BY question_id ASC, sort_order ASC, option_key ASC
    </select>
</mapper>
