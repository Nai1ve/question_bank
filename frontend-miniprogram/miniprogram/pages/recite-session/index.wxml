<view class="page-shell recite-session-page">
  <view class="custom-nav">
    <view class="back-button" bindtap="handleBack">‹</view>
    <view class="nav-title">背诵默写</view>
  </view>

  <view wx:if="{{session}}" class="surface-card session-summary">
    <view class="session-summary-top">
      <view>
        <view class="session-title font-title">{{session.bookName}}</view>
        <view class="muted-text content-copy">{{session.dayLabel}} · 共 {{session.totalCount}} 个</view>
      </view>
      <view class="session-mode">{{session.mode === 'cn_to_en' ? '中译英' : '英译中'}}</view>
    </view>
  </view>

  <view class="entry-list">
    <view wx:for="{{entries}}" wx:key="wordId" class="surface-card entry-card">
      <view class="entry-header">
        <view class="entry-index">{{index + 1}}</view>
        <view class="entry-prompt content-copy">{{item.prompt}}</view>
        <view wx:if="{{item.partOfSpeech}}" class="entry-pos">{{item.partOfSpeech}}</view>
      </view>
      <input
        class="entry-input"
        placeholder="{{placeholderText}}"
        value="{{item.inputValue}}"
        data-index="{{index}}"
        bindinput="handleInput"
      />
    </view>
  </view>

  <button class="primary-button recite-session-submit" bindtap="handleSubmit">提交本页默写</button>
</view>
