.recite-session-page {
  background: #f4f7fb;
}

.session-summary {
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(65, 84, 112, 0.08);
}

.session-summary-top,
.entry-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.session-summary-top {
  justify-content: space-between;
  align-items: flex-start;
}

.session-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #162033;
  margin-bottom: 12rpx;
  line-height: 1.35;
}

.session-mode {
  min-width: 112rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: #edf5ff;
  color: #245a9c;
  font-size: 22rpx;
  line-height: 52rpx;
  text-align: center;
  font-family: "DengXian", "FangSong", "KaiTi", serif;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.entry-card {
  padding: 26rpx;
  border: 2rpx solid rgba(65, 84, 112, 0.07);
  box-shadow: 0 12rpx 30rpx rgba(17, 24, 39, 0.05);
}

.entry-index {
  width: 46rpx;
  height: 46rpx;
  border-radius: 15rpx;
  background: #f2f5f8;
  color: #7c8797;
  font-size: 22rpx;
  line-height: 46rpx;
  text-align: center;
  flex-shrink: 0;
}

.entry-prompt {
  flex: 1;
  font-size: 30rpx;
  color: #162033;
  font-weight: 600;
  min-width: 0;
}

.entry-pos {
  font-size: 22rpx;
  color: #8c93a1;
  flex-shrink: 0;
}

.entry-input {
  margin-top: 20rpx;
  height: 88rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #162033;
  border: 2rpx solid #edf1f6;
}

.recite-session-submit {
  margin-bottom: calc(env(safe-area-inset-bottom) + 10rpx);
}
