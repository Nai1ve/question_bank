.list-page {
  background: #f7f7f5;
}

.group-panel {
  padding: 30rpx;
  margin-bottom: 26rpx;
}

.direct-panel {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.group-header {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 35rpx;
  font-weight: 600;
  color: #272727;
}

.group-subtitle {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #afb5be;
}

.leaf-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.leaf-chip {
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  background: #eef3fb;
  color: #365070;
  font-size: 27rpx;
  line-height: 1.2;
}
