.recite-days-page {
  background: #f4f7fb;
}

.plan-summary {
  padding: 28rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(65, 84, 112, 0.08);
}

.plan-summary-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #162033;
  margin-bottom: 12rpx;
  line-height: 1.35;
}

.plan-current {
  min-width: 130rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #edf5ff;
  text-align: center;
  box-sizing: border-box;
}

.plan-current-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #245a9c;
  line-height: 1.2;
}

.plan-current-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #6d7d92;
}

.day-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.day-card {
  padding: 26rpx;
  border: 2rpx solid rgba(65, 84, 112, 0.07);
  box-shadow: 0 12rpx 30rpx rgba(17, 24, 39, 0.05);
}

.day-card-completed {
  border-color: rgba(41, 163, 122, 0.32);
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.day-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #162033;
  line-height: 1.25;
}

.day-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a94a3;
}

.day-status {
  min-width: 116rpx;
  height: 48rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #526071;
  font-size: 22rpx;
  line-height: 48rpx;
  text-align: center;
  font-family: "DengXian", "FangSong", "KaiTi", serif;
}

.day-progress-track {
  height: 10rpx;
  border-radius: 999rpx;
  background: #e5ebf2;
  overflow: hidden;
}

.day-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #3f7fc4 0%, #29a37a 100%);
}

.day-meta {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #5c6878;
}

.mode-status-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.mode-chip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  min-height: 54rpx;
  min-width: 220rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #f2f5f8;
  color: #526071;
  font-size: 22rpx;
  line-height: 1.4;
  font-family: "DengXian", "FangSong", "KaiTi", serif;
  box-sizing: border-box;
}

.mode-chip-completed {
  background: #e8f5ef;
  color: #217456;
}

.mode-chip-state {
  font-size: 20rpx;
  color: inherit;
}

.day-action {
  margin-top: 20rpx;
  min-height: 56rpx;
  border-radius: 16rpx;
  background: #edf5ff;
  font-size: 24rpx;
  line-height: 56rpx;
  color: #245a9c;
  text-align: center;
  font-family: "DengXian", "FangSong", "KaiTi", serif;
}

.day-action-muted {
  background: #f4f6f8;
  color: #7c8797;
}
