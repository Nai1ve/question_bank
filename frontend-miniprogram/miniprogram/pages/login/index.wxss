.login-page {
  position: relative;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 34rpx) 36rpx calc(env(safe-area-inset-bottom) + 84rpx);
  box-sizing: border-box;
  overflow: hidden;
  background:
    radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.9) 0, rgba(255, 255, 255, 0) 8rpx),
    radial-gradient(circle at 78% 34%, rgba(255, 255, 255, 0.76) 0, rgba(255, 255, 255, 0) 7rpx),
    radial-gradient(circle at 58% 62%, rgba(255, 255, 255, 0.82) 0, rgba(255, 255, 255, 0) 6rpx),
    linear-gradient(180deg, #d7d9df 0%, #cfd2d8 42%, #d9d7d4 100%);
}

.login-noise,
.login-overlay {
  position: absolute;
  inset: 0;
}

.login-noise {
  opacity: 0.08;
  background-image:
    linear-gradient(0deg, transparent 24%, rgba(255, 255, 255, 0.6) 25%, transparent 26%),
    linear-gradient(90deg, transparent 24%, rgba(255, 255, 255, 0.4) 25%, transparent 26%);
  background-size: 14rpx 14rpx;
}

.login-overlay {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.14) 0%, rgba(255, 255, 255, 0.04) 100%);
}

.login-body {
  position: relative;
  z-index: 1;
  min-height: calc(100vh - env(safe-area-inset-top) - env(safe-area-inset-bottom) - 72rpx);
  display: flex;
  flex-direction: column;
}

.login-topline {
  font-size: 32rpx;
  color: #3f4751;
  margin-bottom: 52rpx;
}

.buff-stage {
  display: flex;
  justify-content: flex-end;
  padding-right: 38rpx;
  margin-top: 24rpx;
  margin-bottom: 30rpx;
}

.buff-image {
  width: 226rpx;
  height: 288rpx;
  opacity: 0.72;
}

.hero-copy {
  margin-top: 18rpx;
  padding-left: 34rpx;
}

.hero-title {
  font-size: 64rpx;
  font-weight: 700;
  color: #111111;
  line-height: 1.12;
}

.brand-text {
  margin-top: 28rpx;
  font-size: 54rpx;
  font-weight: 600;
  color: #1b1b1b;
  line-height: 1.12;
  text-align: right;
  padding-right: 54rpx;
}

.wechat-button {
  margin-top: 106rpx;
  height: 102rpx;
  border-radius: 999rpx;
  border: none;
  background: rgba(255, 255, 255, 0.94);
  color: #111111;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 42rpx rgba(17, 24, 39, 0.12);
}

.wechat-button::after {
  border: none;
}

.agreement-text {
  position: relative;
  z-index: 1;
  margin-top: 36rpx;
  text-align: center;
  color: rgba(84, 90, 100, 0.72);
  font-size: 23rpx;
}
