<view class="page-shell recite-plan-page">
  <view class="custom-nav">
    <view class="back-button" bindtap="handleBack">‹</view>
    <view class="nav-title">背诵计划</view>
  </view>

  <view wx:if="{{activePlan}}" class="surface-card current-plan-card">
    <view class="current-plan-topline">
      <view>
        <view class="card-title content-copy">当前计划</view>
        <view class="current-plan-name font-title">{{activePlan.bookName}}</view>
      </view>
      <view class="plan-percent font-title">{{activePlan.progressPercent}}%</view>
    </view>
    <view class="plan-progress-track">
      <view class="plan-progress-fill" style="{{activePlan.progressStyle}}"></view>
    </view>
    <view class="current-plan-meta">
      <view class="plan-meta-item">
        <view class="plan-meta-value font-title">{{activePlan.currentDayLabel}}</view>
        <view class="plan-meta-label content-copy">当前进度</view>
      </view>
      <view class="plan-meta-item">
        <view class="plan-meta-value font-title">{{activePlan.completedDays}} / {{activePlan.totalDays}}</view>
        <view class="plan-meta-label content-copy">完成 Day</view>
      </view>
      <view class="plan-meta-item">
        <view class="plan-meta-value font-title">{{activePlan.dailyCount}}</view>
        <view class="plan-meta-label content-copy">每日单词</view>
      </view>
    </view>
    <button class="ghost-button card-button" bindtap="handleOpenDays">进入 Day 列表</button>
  </view>

  <view class="section-heading font-title">选择词库</view>
  <view class="book-grid">
    <view
      wx:for="{{books}}"
      wx:key="id"
      class="{{item.className}}"
      data-id="{{item.id}}"
      bindtap="handleSelectBook"
    >
      <view class="book-card-header">
        <view class="book-name font-title">{{item.name}}</view>
        <view class="book-count">{{item.totalWords}}</view>
      </view>
      <view class="book-description content-copy">{{item.description}}</view>
      <view class="book-meta content-copy">共 {{item.totalWords}} 个单词</view>
    </view>
  </view>

  <view class="section-heading font-title plan-heading">每日数量</view>
  <view class="filter-chip-row">
    <view
      wx:for="{{countOptions}}"
      wx:key="value"
      class="{{item.className}}"
      data-value="{{item.value}}"
      bindtap="handleSelectCount"
    >
      {{item.label}}
    </view>
  </view>

  <button class="primary-button recite-plan-primary" bindtap="handleCreatePlan">
    {{activePlan ? '重建背诵计划' : '创建背诵计划'}}
  </button>
</view>
