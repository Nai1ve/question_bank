<view class="page-shell recite-study-page">
  <view class="custom-nav">
    <view class="back-button" bindtap="handleBack">‹</view>
    <view class="nav-title font-title">学习单词</view>
  </view>

  <view wx:if="{{study}}" class="surface-card study-summary">
    <view class="study-title font-title">{{study.bookName}} · {{study.dayLabel}}</view>
    <view class="muted-text content-copy">共 {{study.totalCount}} 个单词，先完整浏览，再进入默写测试。</view>
  </view>

  <view class="study-list">
    <view wx:for="{{study.items}}" wx:key="wordId" class="surface-card study-card">
      <view class="study-word font-title">{{item.english}}</view>
      <view class="study-meaning content-copy">{{item.chinese}}</view>
      <view wx:if="{{item.partOfSpeech}}" class="study-pos">{{item.partOfSpeech}}</view>
    </view>
  </view>

  <view class="study-action-group">
    <button
      class="ghost-button study-action"
      data-mode="cn_to_en"
      loading="{{loadingMode === 'cn_to_en'}}"
      bindtap="handleStartMode"
    >
      开始中译英
    </button>
    <button
      class="primary-button study-action"
      data-mode="en_to_cn"
      loading="{{loadingMode === 'en_to_cn'}}"
      bindtap="handleStartMode"
    >
      开始英译中
    </button>
  </view>
</view>
