.recite-study-page {
  background: #f4f7fb;
}

.study-summary,
.study-card {
  padding: 28rpx;
}

.study-summary {
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(65, 84, 112, 0.08);
}

.study-summary-top,
.study-card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.study-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #162033;
  margin-bottom: 12rpx;
  line-height: 1.35;
}

.study-count {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #edf5ff;
  color: #245a9c;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
}

.study-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.study-card {
  border: 2rpx solid rgba(65, 84, 112, 0.07);
  box-shadow: 0 12rpx 30rpx rgba(17, 24, 39, 0.05);
}

.study-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  background: #f2f5f8;
  color: #7c8797;
  font-size: 22rpx;
  line-height: 48rpx;
  text-align: center;
  flex-shrink: 0;
}

.study-word-block {
  flex: 1;
}

.study-word {
  font-size: 34rpx;
  font-weight: 700;
  color: #162033;
  line-height: 1.2;
}

.study-meaning {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
  font-size: 28rpx;
  color: #364254;
}

.study-pos {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a94a3;
  font-family: "DengXian", "FangSong", "KaiTi", serif;
}

.study-action-group {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.study-action {
  flex: 1;
  min-width: 0;
}
