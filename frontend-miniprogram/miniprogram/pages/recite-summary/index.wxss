.recite-summary-page {
  background: #f4f7fb;
}

.summary-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(65, 84, 112, 0.08);
}

.summary-topline {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #162033;
  line-height: 1.35;
}

.summary-mode {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7c8797;
}

.summary-score {
  min-width: 104rpx;
  height: 70rpx;
  border-radius: 20rpx;
  background: #e8f5ef;
  color: #217456;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 70rpx;
  text-align: center;
}

.summary-metrics {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 26rpx;
}

.metric-item {
  text-align: center;
  min-height: 96rpx;
  padding: 14rpx 8rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
  box-sizing: border-box;
}

.metric-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #162033;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a94a3;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.result-card {
  padding: 24rpx;
  border: 2rpx solid rgba(65, 84, 112, 0.07);
  box-shadow: 0 12rpx 30rpx rgba(17, 24, 39, 0.05);
}

.result-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.result-index {
  width: 46rpx;
  height: 46rpx;
  border-radius: 15rpx;
  background: #f2f5f8;
  color: #7c8797;
  font-size: 22rpx;
  line-height: 46rpx;
  text-align: center;
  flex-shrink: 0;
}

.result-prompt {
  flex: 1;
  font-size: 28rpx;
  color: #162033;
  font-weight: 600;
  min-width: 0;
}

.result-badge {
  min-width: 52rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
}

.result-badge-correct {
  background: #e6f5ec;
  color: #2c7b4f;
}

.result-badge-wrong {
  background: #fdeaea;
  color: #b44747;
}

.result-meta,
.result-user {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #5f6c7c;
}

.answer-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
}

.answer-label {
  width: 56rpx;
  color: #8a94a3;
  font-size: 22rpx;
  flex-shrink: 0;
}

.answer-value {
  flex: 1;
  min-width: 0;
  color: #364254;
  font-size: 24rpx;
}

.summary-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 8rpx);
}

.action-button {
  flex: 1;
}

.primary-button {
  height: 72rpx;
  border-radius: 22rpx;
  background: #111111;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 72rpx;
}

.primary-button::after {
  border: none;
}
