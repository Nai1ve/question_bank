.wrong-book-page {
  background: linear-gradient(180deg, #f6f7f4 0%, #eef2f7 100%);
}

.wrong-book-intro,
.wrong-book-card {
  padding: 28rpx;
}

.wrong-book-intro {
  margin-bottom: 24rpx;
}

.intro-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 12rpx;
}

.intro-button {
  margin-top: 22rpx;
}

.wrong-book-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.wrong-book-category {
  font-size: 24rpx;
  color: #7a8595;
  margin-bottom: 10rpx;
}

.wrong-book-stem {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.wrong-book-meta {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #5d6979;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f0f3f8;
  color: #586577;
  font-size: 22rpx;
}
