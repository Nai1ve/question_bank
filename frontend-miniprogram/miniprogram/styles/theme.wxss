.page-shell {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 60rpx) 32rpx calc(env(safe-area-inset-bottom) + 56rpx);
  box-sizing: border-box;
  font-family: "DengXian", "FangSong", "KaiTi", serif;
}

.page-shell-tabbed {
  padding-bottom: calc(env(safe-area-inset-bottom) + 176rpx);
}

.surface-card {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 42rpx rgba(17, 24, 39, 0.07);
}

.avatar-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #e7edf6 0%, #cfd9e7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #435266;
  font-size: 32rpx;
  font-weight: 600;
}

.ghost-button {
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 20rpx;
  border: 1rpx solid #b5bdc8;
  background: #ffffff;
  color: #556171;
  font-size: 25rpx;
  line-height: 72rpx;
  box-shadow: 0 10rpx 24rpx rgba(17, 24, 39, 0.05);
  font-family: "DengXian", "FangSong", "KaiTi", serif;
}

.ghost-button::after {
  border: none;
}

.section-heading {
  font-size: 44rpx;
  font-weight: 700;
  color: #111111;
  font-family: "Microsoft YaHei", "SimHei", "PingFang SC", sans-serif;
}

.muted-text {
  color: #9097a3;
  font-size: 24rpx;
  font-family: "DengXian", "FangSong", "KaiTi", serif;
}

.custom-nav {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 34rpx;
}

.back-button {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(17, 24, 39, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #111111;
}

.nav-title {
  font-size: 38rpx;
  font-weight: 600;
  color: #111111;
  font-family: "Microsoft YaHei", "SimHei", "PingFang SC", sans-serif;
}

.font-title {
  font-family: "Microsoft YaHei", "SimHei", "PingFang SC", sans-serif;
}

.font-body {
  font-family: "DengXian", "FangSong", "KaiTi", serif;
}

.content-copy {
  font-family: "DengXian", "FangSong", "KaiTi", serif;
  line-height: 1.5;
}

.primary-button {
  height: 100rpx;
  border-radius: 999rpx;
  border: none;
  background: #111111;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 18rpx 34rpx rgba(17, 24, 39, 0.16);
  font-family: "DengXian", "FangSong", "KaiTi", serif;
}

.primary-button::after {
  border: none;
}
